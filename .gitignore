# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Virtual envs
.venv/
venv/
env/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Secrets — never commit real keys
.env
.env.*
!.env.example

# Benchmark run artifacts (regenerated; keep them out of git)
runs/
*.parquet
*.duckdb

# Generated calibration / judge analysis outputs (regenerated from committed inputs)
analysis/*
# …except the committed annotation packet (its private/ working dir stays ignored).
!analysis/annotation_round_v0_1
analysis/annotation_round_v0_1/private/
# …and the committed quality-improvement backlog (a tracked planning doc, not a generated output).
!analysis/quality_improvement_backlog.md

# Real human annotations may carry PII — keep them out of git; only synthetic pilots are committed.
# The private dir itself is tracked (README + .gitkeep) but its label files never are.
data/gold/private/*
!data/gold/private/README.md
!data/gold/private/.gitkeep

# OS / editor cruft
.DS_Store
.idea/
.vscode/
*.swp
