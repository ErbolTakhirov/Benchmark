# CompanionBench — example environment file.
#
# Copy to `.env` and fill in the keys for the providers you want to use:
#     cp .env.example .env
#
# NEVER commit your real `.env`. It is gitignored by default.
# The mocked smoke benchmark needs NONE of these — it runs fully offline.

# --- OpenAI ---------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Anthropic ------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# --- OpenRouter -----------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Hugging Face Inference Providers -------------------------------------
HF_TOKEN=
HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1

# --- Generic OpenAI-compatible endpoint -----------------------------------
# Point this at any OpenAI-compatible server (vLLM, Ollama, LM Studio, ...).
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=http://localhost:8000/v1
